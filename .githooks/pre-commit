#!/usr/bin/env bash
#
# StringZilla pre-commit hook.
#
# Rejects decorative comment separators - runs of three or more `-` or `=`
# characters used purely as visual dividers inside C/C++ comments. Proper
# sentences communicate structure better than attention-grabbing rules, so
# the house style bans these banners outright.
#
# Install once per clone with:  git config core.hooksPath .githooks
# Bypass in a genuine emergency with:  git commit --no-verify

set -u

# Only inspect C/C++ translation units and headers.
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM \
    -- '*.c' '*.h' '*.hpp' '*.cpp' '*.cc' '*.cxx' '*.cu' '*.cuh' '*.inl')

[ "${#staged[@]}" -eq 0 ] && exit 0

violations=0
for file in "${staged[@]}"; do
    [ -f "$file" ] || continue
    # Examine only the lines this commit adds (leading '+', excluding the
    # '+++' file header), and flag any comment carrying a 3+ run of - or =.
    while IFS= read -r line; do
        added="${line#+}"
        if printf '%s\n' "$added" | grep -qE '(//|/\*|^\s*\*).*[-=]{3,}'; then
            if [ "$violations" -eq 0 ]; then
                printf 'Decorative comment separators are not allowed (--- / ===):\n\n' >&2
            fi
            printf '  %s: %s\n' "$file" "$(printf '%s' "$added" | sed 's/^[[:space:]]*//')" >&2
            violations=$((violations + 1))
        fi
    done < <(git diff --cached -U0 -- "$file" | grep -E '^\+' | grep -vE '^\+\+\+')
done

if [ "$violations" -ne 0 ]; then
    printf '\nWrite a plain sentence instead, or bypass with --no-verify.\n' >&2
    exit 1
fi

exit 0
